<h1>Search#index</h1>
<p>Find me in app/views/search/index.html.erb</p>

<% if @query.present? %>
  <p>Showing results for: <strong><%= h(@query) %></strong> (<%= @scope.capitalize %>)</p>
<% else %>
  <p>Type something above to search.</p>
<% end %>

<% if @results.present? %>
  <ul class="list-unstyled">
    <% @results.each do |item| %>
      <li class="mb-3 p-3 border rounded">
        <h4><%= link_to item.title, item_path(item) %></h4>
        <p class="text-muted mb-1">
          <%= item.category %>
          ·
          <%= item.college&.name %>
          ·
          <%= item.status.capitalize %>
        </p>
        <p><%= truncate(item.description, length: 160) %></p>
      </li>
    <% end %>
  </ul>
<% elsif @query.present? %>
  <p>No items found. Try broader terms or check spelling.</p>
<% end %>